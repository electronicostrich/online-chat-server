{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -b",
    "start": "node dist/index.js",
    "test": "vitest run --dir test/unit",
    "test:unit": "vitest run --dir test/unit",
    "test:integration": "vitest run --dir test/integration --passWithNoTests",
    "test:smoke": "vitest run --dir test/unit --reporter=dot",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "echo 'seed: not yet implemented (WS-02)' && exit 0"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.0",
    "@fastify/sensible": "^6.0.0",
    "@fastify/type-provider-typebox": "^5.0.0",
    "@node-rs/argon2": "^2.0.0",
    "@sinclair/typebox": "^0.33.0",
    "drizzle-orm": "^0.36.0",
    "fastify": "^5.2.0",
    "fastify-plugin": "^5.0.0",
    "ioredis": "^5.4.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "postgres": "^3.4.0",
    "shared-schemas": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^2.1.0",
    "drizzle-kit": "^0.28.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
